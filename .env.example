# Application — public, required in production, BCP 47/i18n-neutral URL base
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public and required; publishable values are safe only with RLS
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-cloud-publishable-key

# Server-only and optional in Phase 3. Never prefix secrets with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=replace-only-when-a-trusted-server-operation-needs-it

# AI Intake — disabled works without credentials. Gateway uses Vercel OIDC or server-only gateway credentials.
AI_PROVIDER=disabled
AI_MODEL=openai/gpt-5.4
AI_TIMEOUT_MS=20000
AI_MAX_OUTPUT_TOKENS=1200
AI_TEMPERATURE=0

# Inbound email (server-only). Use a dedicated receiving subdomain.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=inbound.qualifyrai.com
