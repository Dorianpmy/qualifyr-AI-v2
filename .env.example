# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (publishable values, safe for the browser when RLS is enabled)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-cloud-publishable-key

# Server-only. Never prefix secrets with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=replace-only-when-a-trusted-server-operation-needs-it

# AI is intentionally disabled in this foundation. Future provider secrets stay server-only.
AI_PROVIDER=disabled
